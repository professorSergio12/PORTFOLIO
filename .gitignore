# Raw uncompressed videos (use compressed versions in repo)
src/assets/**/*.mp4
!src/assets/**/compressed/*.mp4
!src/assets/**/compressed/**/*.mp4
!src/assets/birthday-planner/*.mp4
!src/assets/birthday-planner/**/*.mp4

# Raw reel sources (keep compressed .mp4 in repo)
src/assets/makeup-artist/compressed/reels/*.{MOV,mov}

# Wedding planner raw sources (keep JPG + compressed in repo)
src/assets/wedding-planner/**/*.HEIC
src/assets/wedding-planner/**/*.heic
src/assets/wedding-planner/**/*.MOV
src/assets/wedding-planner/**/*.mov
src/assets/wedding-planner/Decor/*.png
src/assets/wedding-planner/Decor/*.PNG
